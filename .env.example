# ---- LLM (Groq) ----
GROQ_API_KEY=

# ---- Embeddings ----
# Local, free, no API key needed — runs in-process via @xenova/transformers
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ---- Qdrant (vector store) ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- Turso (SQL: accounts, goals, audit trail) ----
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- MongoDB Atlas (conversation logs, nudge history, simulation snapshots) ----
MONGODB_URI=

# ---- Clerk (auth) ----
# Same publishable key value in both — Next.js needs the NEXT_PUBLIC_ prefix
# to expose it to the browser; the Express backend's @clerk/express SDK reads
# the plain (unprefixed) name instead and won't start without it.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Staff/admin access ----
# Comma-separated Clerk user IDs allowed to view the bank-helper staff dashboard.
ADMIN_USER_IDS=

# ---- App ----
PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NODE_ENV=development
